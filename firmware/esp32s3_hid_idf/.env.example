# hidbridge Wi-Fi credentials.
# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored. If WIFI_SSID stays "changeme" (or .env is absent), Wi-Fi
# is not started and the bridge runs cable + BLE only.
WIFI_SSID=changeme
WIFI_PASSWORD=changeme
# Shared secret for OTA updates; set the same value in the daemon's config.json
# "otaToken". Leave at "changeme" only if you don't care who can reflash on your LAN.
OTA_TOKEN=changeme
